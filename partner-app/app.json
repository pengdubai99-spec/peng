{
  "expo": {
    "name": "PENG Partner",
    "slug": "peng-partner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050510"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.peng.partner",
      "infoPlist": {
        "NSCameraUsageDescription": "PENG Partner canli arac kamerasini izlemek icin gereklidir.",
        "NSMicrophoneUsageDescription": "PENG Partner ses almak icin mikrofona erisim gerektirir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#050510"
      },
      "package": "com.peng.partner",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAZYIRO29w3ZCCnMQ51J6xk7Yx4M-PYCn4"
        }
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "a9a9ec9a-257c-4c5a-bd27-b659ba2749c7"
      }
    }
  }
