# SafeRide Environment Variables

# Database
DATABASE_URL=postgresql://saferide:saferide_dev@localhost:5432/saferide
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# AWS S3 / Cloud Storage
STORAGE_BUCKET=saferide-videos
STORAGE_REGION=eu-central-1
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key

# Push Notifications
FCM_SERVER_KEY=your-firebase-cloud-messaging-key

# SMS Gateway
SMS_API_KEY=your-sms-api-key
SMS_SENDER=SafeRide

# Kafka
KAFKA_BROKERS=localhost:9092

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081
